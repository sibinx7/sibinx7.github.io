 0",".",[31,512,513,517],{},[50,514,515],{"align":36},[53,516,263],{},[50,518,519],{"align":36},"Element bounding box has stopped moving across consecutive animation frames.",[31,521,522,526],{},[50,523,524],{"align":36},[53,525,266],{},[50,527,528],{"align":36},"Element is not obscured by overlay elements at the hit-test point.",[31,530,531,535],{},[50,532,533],{"align":36},[53,534,269],{},[50,536,537,538,541],{"align":36},"Element does not have the ",[62,539,540],{},"disabled"," attribute.",[31,543,544,548],{},[50,545,546],{"align":36},[53,547,272],{},[50,549,550,551,554],{"align":36},"Element is not ",[62,552,553],{},"readonly"," and can receive input.",[22,556],{},[237,558,560,561,564],{"id":559},"web-first-assertions-expect","Web-First Assertions (",[62,562,563],{},"expect",")",[242,566,567,568,571],{},"Playwright provides auto-retrying web-first assertions using ",[62,569,570],{},"expect()",". They repeatedly check conditions until met or timed out.",[25,573,574,585],{},[28,575,576],{},[31,577,578,581,583],{},[34,579,580],{"align":36},"Assertion Type",[34,582,43],{"align":36},[34,584,40],{"align":36},[45,586,587,602,617,632,647,662,677,692,707,722,737,752,767],{},[31,588,589,594,599],{},[50,590,591],{"align":36},[53,592,593],{},"Visibility",[50,595,596],{"align":36},[62,597,598],{},"expect(locator).to_be_visible()",[50,600,601],{"align":36},"Asserts element is visible in the DOM.",[31,603,604,609,614],{},[50,605,606],{"align":36},[53,607,608],{},"Invisibility",[50,610,611],{"align":36},[62,612,613],{},"expect(locator).to_be_hidden()",[50,615,616],{"align":36},"Asserts element is hidden or detached.",[31,618,619,624,629],{},[50,620,621],{"align":36},[53,622,623],{},"Enabled State",[50,625,626],{"align":36},[62,627,628],{},"expect(locator).to_be_enabled()",[50,630,631],{"align":36},"Asserts form element is enabled.",[31,633,634,639,644],{},[50,635,636],{"align":36},[53,637,638],{},"Disabled State",[50,640,641],{"align":36},[62,642,643],{},"expect(locator).to_be_disabled()",[50,645,646],{"align":36},"Asserts element is disabled.",[31,648,649,654,659],{},[50,650,651],{"align":36},[53,652,653],{},"Checked State",[50,655,656],{"align":36},[62,657,658],{},"expect(locator).to_be_checked()",[50,660,661],{"align":36},"Asserts checkbox or radio is checked.",[31,663,664,669,674],{},[50,665,666],{"align":36},[53,667,668],{},"Exact Text",[50,670,671],{"align":36},[62,672,673],{},"expect(locator).to_have_text(\"Submit\")",[50,675,676],{"align":36},"Asserts exact inner text matches.",[31,678,679,684,689],{},[50,680,681],{"align":36},[53,682,683],{},"Substring \u002F Regex Text",[50,685,686],{"align":36},[62,687,688],{},"expect(locator).to_contain_text(\"Welcome\")",[50,690,691],{"align":36},"Asserts partial text content match.",[31,693,694,699,704],{},[50,695,696],{"align":36},[53,697,698],{},"Input Value",[50,700,701],{"align":36},[62,702,703],{},"expect(locator).to_have_value(\"admin\")",[50,705,706],{"align":36},"Asserts input element current value.",[31,708,709,714,719],{},[50,710,711],{"align":36},[53,712,713],{},"Attribute Value",[50,715,716],{"align":36},[62,717,718],{},"expect(locator).to_have_attribute(\"type\", \"submit\")",[50,720,721],{"align":36},"Asserts element attribute value.",[31,723,724,729,734],{},[50,725,726],{"align":36},[53,727,728],{},"CSS Class",[50,730,731],{"align":36},[62,732,733],{},"expect(locator).to_have_class(\"btn active\")",[50,735,736],{"align":36},"Asserts element CSS class list.",[31,738,739,744,749],{},[50,740,741],{"align":36},[53,742,743],{},"Count",[50,745,746],{"align":36},[62,747,748],{},"expect(locator).to_have_count(5)",[50,750,751],{"align":36},"Asserts number of matching DOM elements.",[31,753,754,759,764],{},[50,755,756],{"align":36},[53,757,758],{},"Page Title",[50,760,761],{"align":36},[62,762,763],{},"expect(page).to_have_title(\"Dashboard\")",[50,765,766],{"align":36},"Asserts page title matching exact or regex.",[31,768,769,774,779],{},[50,770,771],{"align":36},[53,772,773],{},"Page URL",[50,775,776],{"align":36},[62,777,778],{},"expect(page).to_have_url(\"https:\u002F\u002Fexample.com\u002Flogin\")",[50,780,781],{"align":36},"Asserts active page URL string.",[22,783],{},[237,785,787],{"id":786},"interview-questions-answers","Interview Questions & Answers",[25,789,790,800],{},[28,791,792],{},[31,793,794,797],{},[34,795,796],{"align":36},"Question",[34,798,799],{"align":36},"Answer",[45,801,802,833,851,867,877,898,914],{},[31,803,804,814],{},[50,805,806],{"align":36},[53,807,808,810,811],{},[62,809,306],{}," vs ",[62,812,813],{},"press_sequentially()",[50,815,816,818,819,821,822,502,825,828,829,832],{"align":36},[62,817,306],{}," inserts text instantly as a batch operation. ",[62,820,813],{}," simulates actual typing by triggering ",[62,823,824],{},"keydown",[62,826,827],{},"keypress",", and ",[62,830,831],{},"keyup"," events for every character.",[31,834,835,840],{},[50,836,837],{"align":36},[53,838,839],{},"Bypassing Actionability Checks",[50,841,842,843,846,847,850],{"align":36},"By default Playwright waits for elements to be visible, enabled, and stable before clicking. Pass ",[62,844,845],{},"force=True"," to bypass checks (e.g., ",[62,848,849],{},"click(force=True)",").",[31,852,853,858],{},[50,854,855],{"align":36},[53,856,857],{},"Dynamic File Pickers",[50,859,860,861,864,865,510],{"align":36},"Use ",[62,862,863],{},"page.expect_file_chooser()"," context manager when clicking a custom button opens a file picker dialog instead of a standard ",[62,866,207],{},[31,868,869,874],{},[50,870,871],{"align":36},[53,872,873],{},"What is Auto-Waiting in Playwright?",[50,875,876],{"align":36},"Auto-waiting automatically verifies that target elements satisfy actionability conditions (visible, enabled, stable) before executing actions, eliminating manual sleep statements.",[31,878,879,888],{},[50,880,881],{"align":36},[53,882,883,884,887],{},"How do Web-First Assertions differ from Python ",[62,885,886],{},"assert","?",[50,889,890,891,894,895,897],{"align":36},"Web-first assertions (",[62,892,893],{},"expect(locator)...",") continuously poll the DOM until the condition passes or timeouts. Native ",[62,896,886],{}," checks once immediately and fails if the state hasn't rendered yet.",[31,899,900,905],{},[50,901,902],{"align":36},[53,903,904],{},"How do you invert an assertion in Playwright?",[50,906,860,907,910,911,510],{"align":36},[62,908,909],{},".not_"," before the assertion method, e.g., ",[62,912,913],{},"expect(locator).not_to_be_visible()",[31,915,916,921],{},[50,917,918],{"align":36},[53,919,920],{},"How can you bypass auto-waiting checks?",[50,922,923,924,926,927,510],{"align":36},"Pass ",[62,925,845],{}," parameter to action methods like ",[62,928,929],{},"locator.click(force=True)",{"title":931,"searchDepth":932,"depth":932,"links":933},"",2,[934,936,937,939],{"id":239,"depth":935,"text":240},3,{"id":465,"depth":935,"text":466},{"id":559,"depth":935,"text":938},"Web-First Assertions (expect)",{"id":786,"depth":935,"text":787},"md",{},true,"\u002Finterviews\u002Fplaywright\u002Fdoc\u002Fplaywright-actions",{"title":5,"description":931},"interviews\u002Fplaywright\u002Fdoc\u002Fplaywright-actions","AyQAAsAuWCK7dK0I3SC5Iw6mFMSKGBlsW4EV3_AFp5w",1784557876797]