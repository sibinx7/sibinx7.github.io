[{"data":1,"prerenderedAt":947},["ShallowReactive",2],{"\u002Finterviews\u002Fplaywright\u002Fdoc\u002Fplaywright-actions":3},{"id":4,"title":5,"body":6,"description":931,"extension":940,"meta":941,"navigation":942,"path":943,"seo":944,"stem":945,"__hash__":946},"content\u002Finterviews\u002Fplaywright\u002Fdoc\u002Fplaywright-actions.md","Playwright Python Actions Index",{"type":7,"value":8,"toc":930},"minimark",[9,14,21,24,234,236,241,245,461,463,467,555,557,565,572,782,784,788],[10,11,13],"h1",{"id":12},"playwright-python-actions-inputs","Playwright Python Actions & Inputs",[15,16,17],"ul",{},[18,19,20],"li",{},"Playwright can interact with HTML Input elements such as text inputs, checkboxes, radio buttons, select options, mouse clicks, type characters, keys and shortcuts as well as upload files and focus elements.",[22,23],"hr",{},[25,26,27,44],"table",{},[28,29,30],"thead",{},[31,32,33,38,41],"tr",{},[34,35,37],"th",{"align":36},"left","Topic",[34,39,40],{"align":36},"Description",[34,42,43],{"align":36},"Code Example",[45,46,47,65,80,101,125,160,175,195,214],"tbody",{},[31,48,49,56,59],{},[50,51,52],"td",{"align":36},[53,54,55],"strong",{},"Fill Text",[50,57,58],{"align":36},"Clears the field and enters the string immediately.",[50,60,61],{"align":36},[62,63,64],"code",{},"page.get_by_label(\"Name\").fill(\"John\")",[31,66,67,72,75],{},[50,68,69],{"align":36},[53,70,71],{},"Type Sequentially",[50,73,74],{"align":36},"Types text character-by-character simulating real keyboard delays.",[50,76,77],{"align":36},[62,78,79],{},"page.get_by_role(\"textbox\").press_sequentially(\"Hello\", delay=100)",[31,81,82,87,90],{},[50,83,84],{"align":36},[53,85,86],{},"Check \u002F Uncheck",[50,88,89],{"align":36},"Sets the state of checkboxes or radio buttons.",[50,91,92,95,98],{"align":36},[62,93,94],{},"page.get_by_label(\"Agree\").check()",[96,97],"br",{},[62,99,100],{},"page.get_by_label(\"Subscribe\").uncheck()",[31,102,103,108,115],{},[50,104,105],{"align":36},[53,106,107],{},"Select Option",[50,109,110,111,114],{"align":36},"Selects items in a native ",[62,112,113],{},"\u003Cselect>"," dropdown by value, label, or index.",[50,116,117,120,122],{"align":36},[62,118,119],{},"page.get_by_label(\"Color\").select_option(\"blue\")",[96,121],{},[62,123,124],{},"page.get_by_label(\"Multi\").select_option([\"red\", \"green\"])",[31,126,127,132,135],{},[50,128,129],{"align":36},[53,130,131],{},"Mouse Clicks",[50,133,134],{"align":36},"Performs left click, double click, right click, or modifier clicks.",[50,136,137,140,142,145,147,150,152,155,157],{"align":36},[62,138,139],{},"page.get_by_role(\"button\").click()",[96,141],{},[62,143,144],{},"page.get_by_text(\"Item\").dblclick()",[96,146],{},[62,148,149],{},"page.get_by_text(\"Item\").click(button=\"right\")",[96,151],{},[62,153,154],{},"page.get_by_text(\"Item\").click(modifiers=[\"Shift\"])",[96,156],{},[62,158,159],{},"page.get_by_text(\"Item\").click(position={ \"x\": 0, \"y\": 0})",[31,161,162,167,170],{},[50,163,164],{"align":36},[53,165,166],{},"Hover",[50,168,169],{"align":36},"Hovers mouse over an element to trigger tooltips or menus.",[50,171,172],{"align":36},[62,173,174],{},"page.get_by_role(\"menuitem\").hover()",[31,176,177,182,185],{},[50,178,179],{"align":36},[53,180,181],{},"Key Press",[50,183,184],{"align":36},"Sends single keypresses or key combinations.",[50,186,187,190,192],{"align":36},[62,188,189],{},"page.get_by_label(\"Search\").press(\"Enter\")",[96,191],{},[62,193,194],{},"page.get_by_role(\"textbox\").press(\"Control+a\")",[31,196,197,202,209],{},[50,198,199],{"align":36},[53,200,201],{},"Upload Files",[50,203,204,205,208],{"align":36},"Sets files on ",[62,206,207],{},"\u003Cinput type=\"file\">"," elements.",[50,210,211],{"align":36},[62,212,213],{},"page.get_by_label(\"Upload\").set_input_files(\"doc.pdf\")",[31,215,216,221,224],{},[50,217,218],{"align":36},[53,219,220],{},"Focus & Blur",[50,222,223],{"align":36},"Sets or removes keyboard focus on an element.",[50,225,226,229,231],{"align":36},[62,227,228],{},"page.get_by_label(\"Password\").focus()",[96,230],{},[62,232,233],{},"page.get_by_label(\"Password\").blur()",[22,235],{},[237,238,240],"h3",{"id":239},"actionability-checks-auto-waiting","Actionability Checks (Auto-Waiting)",[242,243,244],"p",{},"Before performing any action, Playwright runs actionability checks on the element to ensure the interaction succeeds without flaky waits.",[25,246,247,273],{},[28,248,249],{},[31,250,251,254,258,261,264,267,270],{},[34,252,253],{"align":36},"Action \u002F Method",[34,255,257],{"align":256},"center","Attached",[34,259,260],{"align":256},"Visible",[34,262,263],{"align":256},"Stable",[34,265,266],{"align":256},"Receives Events",[34,268,269],{"align":256},"Enabled",[34,271,272],{"align":256},"Editable",[45,274,275,300,322,344,363,382,404,423,442],{},[31,276,277,286,289,291,293,295,297],{},[50,278,279,282,283],{"align":36},[62,280,281],{},"click()"," \u002F ",[62,284,285],{},"dblclick()",[50,287,288],{"align":256},"Yes",[50,290,288],{"align":256},[50,292,288],{"align":256},[50,294,288],{"align":256},[50,296,288],{"align":256},[50,298,299],{"align":256},"-",[31,301,302,310,312,314,316,318,320],{},[50,303,304,282,307],{"align":36},[62,305,306],{},"fill()",[62,308,309],{},"clear()",[50,311,288],{"align":256},[50,313,288],{"align":256},[50,315,299],{"align":256},[50,317,299],{"align":256},[50,319,288],{"align":256},[50,321,288],{"align":256},[31,323,324,332,334,336,338,340,342],{},[50,325,326,282,329],{"align":36},[62,327,328],{},"check()",[62,330,331],{},"uncheck()",[50,333,288],{"align":256},[50,335,288],{"align":256},[50,337,288],{"align":256},[50,339,288],{"align":256},[50,341,288],{"align":256},[50,343,299],{"align":256},[31,345,346,351,353,355,357,359,361],{},[50,347,348],{"align":36},[62,349,350],{},"select_option()",[50,352,288],{"align":256},[50,354,288],{"align":256},[50,356,288],{"align":256},[50,358,288],{"align":256},[50,360,288],{"align":256},[50,362,299],{"align":256},